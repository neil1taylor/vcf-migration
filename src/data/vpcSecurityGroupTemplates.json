{
  "templates": {
    "Web Server": {
      "inbound": [
        { "protocol": "tcp", "portMin": 80, "portMax": 80, "source": "0.0.0.0/0", "description": "HTTP" },
        { "protocol": "tcp", "portMin": 443, "portMax": 443, "source": "0.0.0.0/0", "description": "HTTPS" },
        { "protocol": "tcp", "portMin": 22, "portMax": 22, "source": "10.0.0.0/8", "description": "SSH from internal" }
      ],
      "outbound": [
        { "protocol": "all", "source": "0.0.0.0/0", "description": "Allow all outbound" }
      ]
    },
    "Application Server": {
