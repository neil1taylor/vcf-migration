        { "protocol": "tcp", "portMin": 22, "portMax": 22, "source": "10.0.0.0/8", "description": "SSH from internal" }
      ],
      "outbound": [
        { "protocol": "all", "source": "0.0.0.0/0", "description": "Allow all outbound" }
      ]
    },
    "Database": {
      "inbound": [
        { "protocol": "tcp", "portMin": 3306, "portMax": 3306, "source": "sg:application-server", "description": "MySQL from app tier" },
        { "protocol": "tcp", "portMin": 5432, "portMax": 5432, "source": "sg:application-server", "description": "PostgreSQL from app tier" },
        { "protocol": "tcp", "portMin": 1521, "portMax": 1521, "source": "sg:application-server", "description": "Oracle from app tier" },
        { "protocol": "tcp", "portMin": 1433, "portMax": 1433, "source": "sg:application-server", "description": "MSSQL from app tier" },
        { "protocol": "tcp", "portMin": 22, "portMax": 22, "source": "10.0.0.0/8", "description": "SSH from internal" }
