        { "protocol": "udp", "portMin": 53, "portMax": 53, "source": "10.0.0.0/8", "description": "DNS UDP" },
        { "protocol": "tcp", "portMin": 389, "portMax": 389, "source": "10.0.0.0/8", "description": "LDAP" },
        { "protocol": "tcp", "portMin": 636, "portMax": 636, "source": "10.0.0.0/8", "description": "LDAPS" }
